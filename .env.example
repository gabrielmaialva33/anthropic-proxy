# Required: Your API key (OpenAI, OpenRouter, Azure, or any OpenAI-compatible provider)
OPENAI_API_KEY="sk-your-api-key-here"

# Optional: Expected Anthropic API key for client validation
# If set, clients must provide this exact API key to access the proxy
ANTHROPIC_API_KEY="your-expected-anthropic-api-key"

# Optional: API base URL (default: https://api.openai.com/v1)
# Change this to use other providers
OPENAI_BASE_URL="https://api.openai.com/v1"

# Optional: Model mappings
BIG_MODEL="gpt-4o"            # Claude opus requests
MIDDLE_MODEL="gpt-4o"         # Claude sonnet requests
SMALL_MODEL="gpt-4o-mini"     # Claude haiku requests

# Optional: Server settings
HOST="0.0.0.0"
PORT="8082"
LOG_LEVEL="INFO"  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# Optional: Performance settings
MAX_TOKENS_LIMIT="16384"
MIN_TOKENS_LIMIT="100"
REQUEST_TIMEOUT="120"
MAX_RETRIES="2"

# ============================================================
# Provider Examples
# ============================================================

# --- OpenRouter (recommended for multi-model access) ---
# OPENAI_API_KEY="sk-or-v1-your-openrouter-key"
# OPENAI_BASE_URL="https://openrouter.ai/api/v1"
# BIG_MODEL="anthropic/claude-3.5-sonnet"
# MIDDLE_MODEL="google/gemini-2.0-flash-exp:free"
# SMALL_MODEL="meta-llama/llama-3.1-8b-instruct:free"

# --- DeepSeek ---
# OPENAI_API_KEY="sk-your-deepseek-key"
# OPENAI_BASE_URL="https://api.deepseek.com/v1"
# BIG_MODEL="deepseek-chat"
# SMALL_MODEL="deepseek-chat"

# --- Azure OpenAI ---
# OPENAI_API_KEY="your-azure-api-key"
# OPENAI_BASE_URL="https://your-resource.openai.azure.com/openai/deployments/your-deployment"
# AZURE_API_VERSION="2024-03-01-preview"
# BIG_MODEL="gpt-4"
# SMALL_MODEL="gpt-35-turbo"

# --- Local models (Ollama, LM Studio, vLLM) ---
# OPENAI_API_KEY="not-needed"
# OPENAI_BASE_URL="http://localhost:11434/v1"
# BIG_MODEL="llama3.1:70b"
# SMALL_MODEL="llama3.1:8b"

# --- OpenAI Reasoning models (o1/o3/o4) ---
# Uses max_completion_tokens automatically, thinking blocks converted
# BIG_MODEL="o3-mini"
# SMALL_MODEL="o4-mini"

# ============================================================
# Custom Headers
# ============================================================
# Format: CUSTOM_HEADER_KEY=value (underscores become hyphens)
# CUSTOM_HEADER_HTTP_REFERER="https://your-app.com"
# CUSTOM_HEADER_X_TITLE="My App"
